{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Transight default capabilities",
  "windows": ["translate", "settings"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-always-on-top",
